{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "composite": false,
    "declaration": false,
    "sourceMap": false,
    "noEmit": true
  },
  "include": ["src/index.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
